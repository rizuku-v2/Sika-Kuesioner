{
  "manifest_version": 3,
  "name": "MySika Kuesioner Otomatis",
  "version": "3.5.0",
  "description": "Mengisi kuesioner EDOM & Layanan di SIKA Unindra secara otomatis dengan tombol yang terintegrasi di halaman.",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon32.png",
    "128": "images/icon192.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://sika.unindra.ac.id/kuesioner*"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/icon192.png"],
      "matches": ["*://sika.unindra.ac.id/*"]
    }
  ]
}